# --- Servidor ---
PORT=8787
VAULT_PATH=/path/to/your/obsidian/vault   # carpeta de tus notas .md

# --- LLM (todo abierto, API OpenAI-compatible) ---
# Para CAMBIAR de modelo/origen, solo edita esto. No se toca código.
#   llama.cpp `./server`  -> http://127.0.0.1:8080
#   Ollama                -> http://127.0.0.1:11434
LLM_PROVIDER=openai-compat
LLM_BASE_URL=http://127.0.0.1:8080     # server de CHAT
LLM_MODEL=local                        # nombre del modelo cargado (llama.cpp acepta cualquiera)
LLM_EMBED_MODEL=nomic-embed-text
# Endpoint de EMBEDDINGS. Un llama.cpp sirve chat O embeddings, no ambos, así que
# aquí puedes apuntar los embeddings a otro server. Si se omite, usa LLM_BASE_URL.
#   Ollama hace las dos: deja ambas en http://127.0.0.1:11434
#   llama.cpp: chat en :8080 y embeddings en otro llama.cpp --embedding (o en Ollama)
# LLM_EMBED_BASE_URL=http://127.0.0.1:11434
# LLM_API_KEY=                         # los servidores locales no lo piden

# --- Vector store ---
STORE=memory                    # memory (cero infra) | pgvector
EMBED_DIM=768                   # dimensión del modelo de embeddings (nomic-embed-text = 768)
# DATABASE_URL=postgres://user:pass@localhost:5432/study   # requerido si STORE=pgvector

# --- RAG ---
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K=5
