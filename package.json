{
  "name": "study-rag-server",
  "version": "0.1.0",
  "description": "Ask-your-vault RAG para el Study Framework. Self-hosted, solo modelos abiertos (llama.cpp/Ollama vía API OpenAI-compatible). LLM y vector store enchufables.",
  "type": "module",
  "license": "MIT",
  "engines": { "node": ">=20.6" },
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/rag/*.test.ts src/llm/*.test.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.6",
    "tsx": "^4.10.0",
    "typescript": "^5.4.5"
  }
}
